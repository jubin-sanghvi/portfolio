---
import type { ExperienceEntry } from '../../data/experience';
import { formatDateRange } from '../../lib/utils';

interface Props {
  entry: ExperienceEntry;
  isLast?: boolean;
}

const { entry } = Astro.props;
---

<div class="timeline-entry reveal">
  <div class="timeline-dot"></div>
  <div class="timeline-content">
    <p class="timeline-company">{entry.company}</p>
    <h3 class="timeline-role">{entry.role}</h3>
    <p class="timeline-meta">{formatDateRange(entry.start, entry.end)} · {entry.location}</p>
    <p class="timeline-summary"><em>{entry.summary}</em></p>
    {entry.tags && entry.tags.length > 0 && (
      <div class="timeline-tags">
        {entry.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</div>

<style>
  .timeline-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .timeline-company {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .timeline-role {
    font-size: var(--text-xl);
    line-height: 1.2;
  }
  .timeline-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .timeline-summary {
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }
  .timeline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
</style>
