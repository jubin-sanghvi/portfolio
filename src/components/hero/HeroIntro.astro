---
import BackgroundBinaryField from './BackgroundBinaryField.astro';
import PortraitFrame from '../common/PortraitFrame.astro';
import CTAButton from '../common/CTAButton.astro';
import { siteConfig } from '../../data/site';
---

<section class="hero" aria-label="Introduction">
  <BackgroundBinaryField />
  <div class="container" style="position:relative;z-index:1;">
    <div class="hero-content">
      <PortraitFrame alt="Jubin Sanghvi" size="lg" />
      <h1 class="hero-name">{siteConfig.name}</h1>
      <p class="hero-role">{siteConfig.role}</p>
      <p class="hero-tagline">{siteConfig.tagline}</p>
      <p class="hero-intro">
        I build Data and AI platforms at scale, and I grow the teams that own them. Over 6 years at Cisco, I've led infrastructure that Product, ML/AI, Data Science, and Engineering teams depend on daily.
      </p>
      <div class="hero-ctas">
        <CTAButton href="/experience" label="View Experience" variant="primary" />
        <CTAButton href="/projects" label="View Projects" variant="secondary" />
        <CTAButton href={siteConfig.resumePath} label="Download Resume" variant="secondary" download={siteConfig.resumeFilename} />
        <CTAButton href={siteConfig.linkedinProfile} label="Connect on LinkedIn" variant="secondary" external={true} />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }
  .hero-name {
    font-size: var(--text-hero);
    line-height: 1.05;
    margin-top: var(--space-6);
  }
  .hero-role {
    font-size: var(--text-lg);
    color: var(--color-accent);
    font-weight: 500;
  }
  .hero-tagline {
    font-size: var(--text-lg);
    font-family: var(--font-body);
    font-weight: 400;
    color: var(--color-text-muted);
  }
  .hero-intro {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 60ch;
    line-height: 1.7;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }
</style>
