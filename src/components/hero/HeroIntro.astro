---
import { Image } from 'astro:assets';
import profilePhoto from '../../assets/images/profile.jpg';
import BackgroundBinaryField from './BackgroundBinaryField.astro';
import { siteConfig } from '../../data/site';
---

<section class="intro" aria-label="Introduction">
  <BackgroundBinaryField />
  <div class="container" style="position:relative;z-index:1;">
    <Image
      src={profilePhoto}
      alt="Jubin Sanghvi"
      width={240}
      height={240}
      style="float: right; max-width: 33%; margin: 0 0 1em 2em; border-radius: 999px"
    />
    <p>
      I'm Jubin Sanghvi, a Senior Engineering Manager at <a href="https://duo.com">Cisco (Duo Security)</a>.
      I build Data and AI platforms at scale, and I grow the teams that own them.
    </p>
    <p>
      My focus is on data infrastructure and AI platform engineering. I've built event-driven and batch
      platforms on Kafka, PySpark, and EMR, then moved into leadership to multiply leverage. Over 6+ years
      at Cisco, I've driven $4M+ in annual savings and contributed to $146.8M in international bookings growth.
    </p>
    <p>
      Today I lead AI Infrastructure at Duo Security — lakehouse modernization, ML enablement,
      threat intelligence, and AI developer tooling. I'm comfortable going deep with engineers on
      system design and giving senior leadership the 10,000-foot view on strategy and trade-offs.
    </p>
    <p>
      I'm active on <a href={siteConfig.githubProfile}>GitHub</a>.
      You can also find me on <a href={siteConfig.linkedinProfile}>LinkedIn</a>.
    </p>
    <p>
      I enjoy building platform infrastructure and collaborating with great teams.
      <a href={siteConfig.linkedinProfile}>Reach out</a> if you want to find a way to work together!
    </p>
  </div>
</section>

<style>
  .intro {
    position: relative;
    overflow: hidden;
    padding: 30px 0;
  }
  .intro p {
    margin-bottom: 15px;
  }
  @media (max-width: 600px) {
    .intro :global(img) {
      float: none !important;
      display: block;
      margin: 0 auto 1em !important;
      max-width: 60% !important;
    }
  }
</style>
