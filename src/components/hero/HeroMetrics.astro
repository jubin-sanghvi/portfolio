---
import MetricCard from '../common/MetricCard.astro';
import { heroMetrics } from '../../data/metrics';
---

<section class="hero-metrics" aria-label="Key achievements">
  <div class="container-wide">
    <div class="metrics-row">
      {heroMetrics.map((metric) => (
        <MetricCard value={metric.value} label={metric.label} sublabel={metric.sublabel} />
      ))}
    </div>
  </div>
</section>

<style>
  .hero-metrics {
    padding: var(--space-12) 0;
  }
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
  }
  @media (max-width: 768px) {
    .metrics-row {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }
</style>
