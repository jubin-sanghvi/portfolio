---
import { Icon } from 'astro-icon/components';
import { siteConfig } from '../../data/site';
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-col footer-col-1">
      <ul class="contact-list">
        <li>
          <a href={siteConfig.linkedinProfile} target="_blank" rel="noopener noreferrer">
            <span class="icon"><Icon name="mdi:linkedin" size={16} /></span>
            jubinsanghvi
          </a>
        </li>
        <li>
          <a href={siteConfig.githubProfile} target="_blank" rel="noopener noreferrer">
            <span class="icon"><Icon name="mdi:github" size={16} /></span>
            jubin-sanghvi
          </a>
        </li>
      </ul>
    </div>
    <div class="footer-col footer-col-2">
      <p>I build Data and AI platforms at scale. I lead engineering teams that own infrastructure Product, ML/AI, and Data Science orgs depend on.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 30px 0;
  }
  .footer-inner {
    max-width: var(--content-default);
    margin-inline: auto;
    padding-inline: 15px;
    display: flex;
    gap: 2rem;
    font-size: 15px;
    color: var(--color-text-muted);
  }
  .footer-col-1 {
    width: 35%;
    min-width: 160px;
  }
  .footer-col-2 {
    width: 60%;
  }
  .contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .contact-list li + li {
    padding-top: 5px;
  }
  .contact-list a {
    display: grid;
    grid-template-columns: 1.4rem auto;
    align-items: center;
    gap: 0;
    color: var(--color-accent);
    text-decoration: none;
  }
  .contact-list a:visited {
    color: var(--color-accent);
  }
  .contact-list a:hover {
    text-decoration: underline;
  }
  .icon {
    display: flex;
    align-items: center;
  }
  .icon :global(svg) {
    width: 16px;
    height: 16px;
  }
  .footer-col-2 p {
    margin: 0;
  }
  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: 1rem;
    }
    .footer-col-1, .footer-col-2 {
      width: 100%;
    }
  }
</style>
