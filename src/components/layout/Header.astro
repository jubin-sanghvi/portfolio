---
import { Icon } from 'astro-icon/components';
import { mainNav } from '../../data/navigation';
import { isActiveRoute } from '../../lib/routes';
import MobileMenu from './MobileMenu.astro';

const currentPath = Astro.url.pathname;
---

<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="site-title" aria-label="Jubin Sanghvi home">
      Jubin Sanghvi
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      {mainNav.map((item) => (
        <a
          href={item.href}
          class={`page-link ${isActiveRoute(currentPath, item.href) ? 'active' : ''}`}
          {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button class="icon-btn hamburger" aria-label="Open menu" aria-expanded="false" id="hamburger-btn">
      <Icon name="mdi:menu" size={20} />
    </button>
  </div>
  <MobileMenu />
</header>

<style>
  .site-title {
    font-size: 26px;
    font-weight: 400;
    line-height: 54px;
    margin-bottom: 0;
    color: #424242;
    text-decoration: none;
  }
  .site-title:visited {
    color: #424242;
  }
  .site-title:hover {
    color: #424242;
    text-decoration: none;
    opacity: 0.7;
  }
  .site-nav {
    line-height: 54px;
  }
  .page-link {
    color: var(--color-text);
    line-height: 1.5;
    text-decoration: none;
  }
  .page-link:visited {
    color: var(--color-text);
  }
  .page-link:not(:last-child) {
    margin-right: 20px;
  }
  .page-link:hover {
    color: var(--color-text);
    text-decoration: underline;
  }
  .page-link.active {
    text-decoration: underline;
  }
</style>
