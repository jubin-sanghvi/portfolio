---
import type { ProjectPlaceholder } from '../../data/projectPlaceholders';
import { siteConfig } from '../../data/site';

interface Props {
  placeholder: ProjectPlaceholder;
}

const { placeholder } = Astro.props;
---

<article class="card reveal">
  <div class="project-card-inner">
    <div class="placeholder-header">
      <h3 class="project-name">
        <a href={siteConfig.githubProfile} target="_blank" rel="noopener noreferrer">{placeholder.title}</a>
      </h3>
      <span class="badge-coming-soon">Coming Soon</span>
    </div>
    <p class="project-desc">{placeholder.description}</p>
    <div class="project-topics">
      {placeholder.tags.map((tag) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }
  .placeholder-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .project-name a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-lg);
  }
  .project-name a:hover {
    color: var(--color-accent);
  }
  .project-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    flex: 1;
  }
  .project-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
