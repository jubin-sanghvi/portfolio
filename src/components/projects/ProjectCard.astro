---
interface Props {
  name: string;
  description: string;
  topics: string[];
  homepage?: string;
  htmlUrl: string;
  updatedAt: string;
}

const { name, description, topics, htmlUrl, updatedAt } = Astro.props;

const displayDate = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<article class="card reveal clickable-card">
  <div class="project-card-inner">
    <h3 class="project-name">
      <a href={htmlUrl} target="_blank" rel="noopener noreferrer">{name}</a>
    </h3>
    <p class="project-desc">{description}</p>
    {
      topics.length > 0 && (
        <div class="project-topics">
          {topics.map((topic) => (
            <span class="tag">{topic}</span>
          ))}
        </div>
      )
    }
    <p class="project-updated">Updated {displayDate}</p>
  </div>
</article>

<style>
  .project-card-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
  }
  .project-name a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-lg);
  }
  .project-name a:hover {
    color: var(--color-accent);
  }
  .clickable-card {
    position: relative;
    cursor: pointer;
  }
  .project-name a::after {
    content: '';
    position: absolute;
    inset: 0;
  }
  .project-desc {
    font-size: var(--text-sm);
    color: var(--color-text);
    flex: 1;
  }
  .project-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .project-updated {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
  }
</style>
