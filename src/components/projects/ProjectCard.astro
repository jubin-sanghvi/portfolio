---
interface Props {
  name: string;
  description: string;
  topics: string[];
  htmlUrl: string;
  updatedAt: string;
  image?: string;
  homepage?: string;
}

const { name, description, topics, htmlUrl, updatedAt, image, homepage } = Astro.props;

const displayDate = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
});
---

<article class="project-entry">
  <h2 class="project-name">
    <a href={htmlUrl} target="_blank" rel="noopener noreferrer">{name}</a>
  </h2>
  {image && <img class="project-image" src={image} alt={`Screenshot of ${name}`} loading="lazy" />}
  <p class="project-desc">{description}</p>
  {
    topics.length > 0 && (
      <div class="project-topics">
        {topics.map((topic) => (
          <span class="tag">{topic}</span>
        ))}
      </div>
    )
  }
  <div class="project-links">
    <a href={htmlUrl} target="_blank" rel="noopener noreferrer">View on GitHub</a>
    {
      homepage && (
        <a href={homepage} target="_blank" rel="noopener noreferrer">
          Live Demo &rarr;
        </a>
      )
    }
  </div>
  <p class="project-updated">Updated {displayDate}</p>
</article>

<style>
  .project-entry {
    overflow: hidden; /* clearfix */
  }
  .project-name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }
  .project-name a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .project-name a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
  .project-image {
    float: left;
    width: 180px;
    margin-right: var(--space-6);
    margin-bottom: var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }
  .project-desc {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }
  .project-topics {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .project-links {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }
  .project-links a {
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
  }
  .project-links a:hover {
    color: var(--color-accent-hover);
    text-decoration: underline;
  }
  .project-updated {
    font-size: var(--text-xs);
    color: var(--color-text-faint);
  }
  @media (max-width: 600px) {
    .project-image {
      float: none;
      width: 100%;
      margin-right: 0;
      margin-bottom: var(--space-4);
    }
  }
</style>
