---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { experience } from '../data/experience';
---

<BaseLayout title="Experience" description="Jubin Sanghvi's professional experience in data infrastructure and AI platform engineering.">
  <section class="page-section">
    <div class="container">
      <h1>Experience</h1>
      {experience.map((company) => (
        <div class="company-group">
          <div class="company-header">
            <h2 class="company-name">{company.company}</h2>
            <span class="company-duration">{company.totalDuration}</span>
          </div>
          <div class="timeline">
            {company.roles.map((role) => (
              <div class="timeline-entry">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                  <h3 class="role-title">{role.title}</h3>
                  <p class="role-meta">
                    {role.start} - {role.end} · {role.location}{role.type ? ` · ${role.type}` : ''}
                  </p>
                  <p class="role-desc">{role.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }
  .company-group {
    margin-bottom: 2rem;
  }
  .company-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .company-name {
    font-size: var(--text-lg);
    margin-bottom: 0;
  }
  .company-duration {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
  .timeline {
    position: relative;
    padding-left: 1.5rem;
    margin-left: 0.25rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: var(--color-border);
  }
  .timeline-entry {
    position: relative;
    padding-bottom: 1.5rem;
  }
  .timeline-entry:last-child {
    padding-bottom: 0;
  }
  .timeline-dot {
    position: absolute;
    left: -1.5rem;
    top: 6px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
    margin-left: -0.5px;
  }
  .role-title {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .role-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }
  .role-desc {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text);
  }
</style>
