---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeading from '../components/common/SectionHeading.astro';
import CTAButton from '../components/common/CTAButton.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout title="Resume" description="Download Jubin Sanghvi's resume — Senior Engineering Manager specializing in AI and Data Infrastructure.">
  <section class="page-section">
    <div class="container" style="text-align:center;">
      <SectionHeading
        eyebrow="Resume"
        title="Download Resume"
        description="Download the latest version of my resume."
        align="center"
      />
      <div style="margin-bottom:var(--space-12);">
        <CTAButton href={siteConfig.resumePath} label="Download Resume (PDF)" variant="primary" download={siteConfig.resumeFilename} />
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom:var(--space-8);">Key highlights</h2>
      <ul class="resume-highlights">
        <li class="reveal">Led AI Infrastructure team at Cisco Duo, driving lakehouse modernization ingesting 50TB/month across Snowflake Iceberg.</li>
        <li class="reveal">Cut $4M+ in annual cloud and maintenance costs across multiple infrastructure modernization projects.</li>
        <li class="reveal">Orchestrated UAE datacenter buildout contributing to $146.8M / 11% YoY international bookings growth.</li>
        <li class="reveal">Built and scaled Customer Logging Platform processing 200M events/day across 6-8 engineering teams.</li>
        <li class="reveal">Grew Data Infrastructure team from 5 to 11 engineers across 4 countries, developing 6 engineers through promotions.</li>
        <li class="reveal">Catalyzed AI-tooling adoption from 43% to 89% across a 300+ engineer org by co-founding the AI Guild.</li>
      </ul>
      <p style="margin-top:var(--space-8);color:var(--color-text-muted);">
        For the full interactive timeline, visit the <a href="/experience">Experience page</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .resume-highlights {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-left: var(--space-6);
    list-style: disc;
  }
  .resume-highlights li {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 72ch;
  }
</style>
